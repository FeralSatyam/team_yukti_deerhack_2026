# ---- HTTP server ----
PORT=5000

# ---- React client (CORS) ----
# Comma-separated list of allowed origins for the browser client.
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

# ---- Python FastAPI microservice ----
ML_SERVICE_URL=http://localhost:8000
# Timeout (ms) for requests to the microservice.
ML_SERVICE_TIMEOUT=30000

# ---- Supabase (PostgreSQL) ----
# Use the connection string from Supabase Dashboard > Project Settings > Database.
# Prefer the "Connection pooling" (Transaction) string on port 6543 for serverless,
# or the direct connection on port 5432. URL-encode special characters in the password.
# Example: postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=
# ...or the individual parts (used only if DATABASE_URL is empty).
PGHOST=
PGPORT=6543
PGUSER=postgres.your-project-ref
PGPASSWORD=
PGDATABASE=postgres

# Supabase requires SSL. Set to "false" only for a plain local Postgres.
DB_SSL=true

# Set to "true" to see SQL logging in the console.
DB_LOGGING=false
