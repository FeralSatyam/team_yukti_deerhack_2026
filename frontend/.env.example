# Optional. By default the app calls the same-origin "/api" path, which the
# Vite dev server proxies to the backend (see vite.config.js). Set this to an
# absolute URL only when the API is hosted on a different origin in production.
# VITE_API_URL=https://api.example.com/api

# Optional. Where the dev proxy forwards "/api" requests (defaults to :5000).
# VITE_PROXY_TARGET=http://localhost:5000
